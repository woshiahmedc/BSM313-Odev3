  63:Core/Src/main.c ****   // PA1 = Земля
  64:Core/Src/main.c ****   HAL_GPIO_WritePin(GPIOA, GPIO_PIN_1, GPIO_PIN_RESET);
  65:Core/Src/main.c **** 
  66:Core/Src/main.c ****   blink_count = ReadFlash();
  67:Core/Src/main.c ****   if (blink_count < 4 || blink_count > 6) {
  68:Core/Src/main.c ****       blink_count = 4;
  69:Core/Src/main.c ****       WriteFlash(blink_count);
  70:Core/Src/main.c ****   }
  71:Core/Src/main.c **** 
  72:Core/Src/main.c ****   // АППАРАТНЫЙ СБРОС (Пункт G)
  73:Core/Src/main.c ****   uint32_t press_start = HAL_GetTick();
  74:Core/Src/main.c ****   while (HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_0) == GPIO_PIN_RESET) {
  75:Core/Src/main.c ****       if (HAL_GetTick() - press_start >= 3000) {
  76:Core/Src/main.c ****           blink_count = 4;
  77:Core/Src/main.c ****           WriteFlash(blink_count);
  78:Core/Src/main.c ****           for(int i=0; i<6; i++) {
  79:Core/Src/main.c ****               HAL_GPIO_TogglePin(GPIOC, GPIO_PIN_13);
  80:Core/Src/main.c ****               HAL_Delay(100);
  81:Core/Src/main.c ****           }
  82:Core/Src/main.c ****           break; // Выходим из цикла СРАЗУ. Никаких зависаний.
  83:Core/Src/main.c ****       }
  84:Core/Src/main.c ****   }
  85:Core/Src/main.c **** 
